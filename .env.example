# Copy this file to .env and fill in your Anthropic API key.
# cp .env.example .env
#
# Runs use MOCK mode by default (no API calls, no key needed). Use --live on the
# command line to use the real API. Key required only for --live runs:
ANTHROPIC_API_KEY=

# Optional overrides (defaults are used if unset):
# SUT_MODEL=claude-haiku-4-5-20251001
# JUDGE_MODEL=claude-sonnet-4-6
# For --judge openai: JUDGE_MODEL_OPENAI=gpt-4o-mini
# NOTIFY_FORMAT=slack   (for Slack-friendly webhook payloads)

# Force mock mode even if --live is passed (e.g. in CI): set to 1, true, or yes.
# SAFETY_TESTER_MOCK=0

# Optional: directory for result JSON and Markdown (default: results/)
# OUTPUT_DIR=results

# Optional: path to a file containing the SUT system prompt (overrides built-in Calm prompt)
# SUT_SYSTEM_PROMPT=path/to/my_prompt.txt

# Optional: API request timeout in seconds (default: 120)
# API_TIMEOUT=120

# --- SUT backend (--sut) ---
# Default: anthropic (uses ANTHROPIC_API_KEY above).
# For --sut openai: set OPENAI_API_KEY (and optionally SUT_MODEL=gpt-4o-mini).
# For --sut custom (customer's API): set SUT_ENDPOINT and optionally SUT_API_KEY.
# OPENAI_API_KEY=
# SUT_ENDPOINT=https://api.example.com/chat
# SUT_API_KEY=
