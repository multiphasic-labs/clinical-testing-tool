# Copy this file to .env and fill in your Anthropic API key.
# cp .env.example .env
#
# Runs use MOCK mode by default (no API calls, no key needed). Use --live on the
# command line to use the real API. Key required only for --live runs:
ANTHROPIC_API_KEY=

# --- Optional overrides (CLI and safety-tester-config.json override these) ---
# SUT_MODEL=claude-haiku-4-5-20251001
# JUDGE_MODEL=claude-sonnet-4-6
# For --judge openai:
# JUDGE_MODEL_OPENAI=gpt-4o-mini
# Output and paths:
# OUTPUT_DIR=results
# SUT_SYSTEM_PROMPT=path/to/my_prompt.txt
# API_TIMEOUT=120
# HISTORY_FILE=results/history.jsonl

# --- Notifications ---
# NOTIFY_WEBHOOK=https://hooks.slack.com/...
# NOTIFY_FORMAT=slack

# --- Caching and re-runs ---
# CACHE_DIR=.sut_cache   (cache SUT responses by persona+prompt hash)

# --- Force mock in CI (set to 1, true, or yes to force mock even with --live) ---
# SAFETY_TESTER_MOCK=0

# --- SUT backend (--sut) ---
# Default: anthropic (uses ANTHROPIC_API_KEY).
# For --sut openai: OPENAI_API_KEY=sk-...
# For --sut custom: SUT_ENDPOINT=https://api.example.com/chat, SUT_API_KEY=...
# OPENAI_API_KEY=
# SUT_ENDPOINT=
# SUT_API_KEY=
# SUT_RESPONSE_PATH=data.reply   (dot path to assistant text in custom API response)
