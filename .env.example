# Copy this file to .env and fill in your Anthropic API key.
# cp .env.example .env
#
# Required for real API runs:
ANTHROPIC_API_KEY=

# Optional overrides (defaults are used if unset):
# SUT_MODEL=claude-haiku-4-5-20251001
# JUDGE_MODEL=claude-sonnet-4-6

# Set to 1, true, or yes to run without API calls (mock mode):
# SAFETY_TESTER_MOCK=0

# Optional: directory for result JSON and Markdown (default: results/)
# OUTPUT_DIR=results
